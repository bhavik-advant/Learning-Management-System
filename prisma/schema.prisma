// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider  = "postgresql"
}
// Enums
enum Role {
  TRAINEE
  MENTOR
  ADMIN
}

enum CourseStatus {
  DRAFT
  PENDING
  APPROVED
}

enum EnrollmentStatus {
  PENDING
  APPROVED
  REJECTED
}

enum FileType {
  IMAGE
  VIDEO
  DOCUMENT
  OTHER
}

// User Model
model User {
  id         String   @id @default(uuid())
  clerkId    String   @unique
  username   String   @unique
  email      String   @unique
  image      String
  role       Role     @default(TRAINEE)
  mentorId   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  mentor     User?    @relation("UserMentor", fields: [mentorId], references: [id], onDelete: SetNull)
  trainees    User[]   @relation("UserMentor")

  courses    Course[] @relation("MentorCourses")
  files      File[]   @relation("UploadedFiles")
  assignments Assignment[] @relation("MentorAssignments")
  submissions Submission[] @relation("StudentSubmissions")
  enrollments Enrollment[]

  @@index([mentorId])
}

// Course Model
model Course {
  id           String        @id @default(uuid())
  title        String
  description  String
  thumbnailId  String?
  status       CourseStatus  @default(DRAFT)
  authorId     String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  author       User          @relation("MentorCourses", fields: [authorId], references: [id])
  thumbnail    File?         @relation("CourseThumbnail", fields: [thumbnailId], references: [id])
  modules      Module[]
  enrollments  Enrollment[]

  @@index([authorId])
  @@index([thumbnailId])
}

// Module Model
model Module {
  id         String   @id @default(uuid())
  title      String
  order      Int
  courseId   String
  createdAt  DateTime @default(now())

  course     Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons    Lesson[]
  assignments Assignment[]

  @@index([courseId])
  @@unique([courseId, order]) // Ensures unique ordering within a course
}

// Lesson Model
model Lesson {
  id           String   @id @default(uuid())
  title        String
  order        Int
  moduleId     String
  videoUrl     String?
  videoFileId  String?
  createdAt    DateTime @default(now())

  // Relations
  module       Module   @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  videoFile    File?    @relation("LessonVideo", fields: [videoFileId], references: [id])

  @@index([moduleId])
  @@index([videoFileId])
  @@unique([moduleId, order])
}

// File Model
model File {
  id          String   @id @default(uuid())
  url         String
  type        FileType
  public_id   String
  size        Int
  createdAt   DateTime @default(now())
  uploadedBy  String

  // Relations
  uploader    User     @relation("UploadedFiles", fields: [uploadedBy], references: [id])
  thumbnails  Course[] @relation("CourseThumbnail")
  lessonVideo Lesson[] @relation("LessonVideo")

  @@index([uploadedBy])
}


enum SubmissionStatus {
  PENDING
  GRADED
  RESUBMITTED
}

model Assignment {
  id          String   @id @default(uuid())
  title       String
  description String
  dueDate     DateTime?
  maxScore    Int      @default(100)
  createdAt   DateTime @default(now())

  moduleId    String
  createdById String

  // Relations
  module      Module   @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  createdBy   User     @relation("MentorAssignments", fields: [createdById], references: [id])
  submissions Submission[]

  @@index([moduleId])
  @@index([createdById])
}

model Submission {
  id          String            @id @default(uuid())
  fileUrl     String
  score       Int?
  feedback    String?
  status      SubmissionStatus  @default(PENDING)
  isActive    Boolean           @default(true)
  submittedAt DateTime          @default(now())
  gradedAt    DateTime?

  assignmentId String
  studentId    String

  assignment  Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  student     User       @relation("StudentSubmissions", fields: [studentId], references: [id], onDelete: Cascade)

  @@index([assignmentId])
  @@index([studentId])
  @@unique([assignmentId, studentId]) 
}


model Enrollment {
  id         String   @id @default(uuid())
  studentId  String
  courseId   String
  createdAt  DateTime @default(now())

  student    User     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  course     Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([courseId])
  @@unique([studentId, courseId]) // Prevents duplicate enrollments
}